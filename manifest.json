{
  "manifest_version": 3,
  "name": "Nullify",
  "version": "2.6.0",
  "minimum_chrome_version": "120",
  "description": "Nullify — reduce ads to nothing. A powerful, privacy-focused ad blocker built on Manifest V3.",
  "author": "Nullify",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "Nullify"
  },
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://m.youtube.com/*",
        "*://music.youtube.com/*"
      ],
      "js": [
        "dist/youtube-shield.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "easylist",
        "enabled": false,
        "path": "rules/easylist.json"
      },
      {
        "id": "easyprivacy",
        "enabled": false,
        "path": "rules/easyprivacy.json"
      },
      {
        "id": "annoyances",
        "enabled": false,
        "path": "rules/annoyances.json"
      },
      {
        "id": "malware",
        "enabled": false,
        "path": "rules/malware.json"
      },
      {
        "id": "ubo-filters",
        "enabled": false,
        "path": "rules/ubo-filters.json"
      },
      {
        "id": "ubo-unbreak",
        "enabled": false,
        "path": "rules/ubo-unbreak.json"
      },
      {
        "id": "system-unbreak",
        "enabled": true,
        "path": "rules/system-unbreak.json"
      },
      {
        "id": "anti-adblock",
        "enabled": false,
        "path": "rules/anti-adblock.json"
      }
    ]
  },
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "scripting",
    "alarms",
    "tabs",
    "webNavigation",
    "privacy",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dist/scriptlets-world.js",
        "dist/nullify_core_bg.wasm"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
